          <div class="snap-center shrink-0 w-[85%] md:w-[320px] flex flex-col items-start bg-white p-6 rounded-xl border border-slate-100 shadow-sm">
            <span class="flex-shrink-0 w-12 h-12 flex items-center justify-center rounded-full bg-[#0A2F5C] text-[#B28D42] font-bold mb-4">✓</span>
