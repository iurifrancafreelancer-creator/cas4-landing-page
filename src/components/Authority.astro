          </div>

        </div>
      </div>

  </div>
</section>

<script>
  // Lógica dos contadores animados
  const animateCounter = (counter) => {
    const target = +counter.getAttribute('data-target');
    const prefix = counter.getAttribute('data-prefix');
    const suffix = counter.getAttribute('data-suffix');
    const duration = 2000; 
    
    let startTimestamp = null;
    
    const step = (timestamp) => {
      if (!startTimestamp) startTimestamp = timestamp;
      const progress = Math.min((timestamp - startTimestamp) / duration, 1);
      
      const easeOutProgress = 1 - Math.pow(1 - progress, 3);
      let currentVal = Math.floor(easeOutProgress * target);
      
      let formattedVal = currentVal;
      if (target >= 1000) {
        formattedVal = currentVal.toString().replace(/\B(?=(\d{3})+(?!\d))/g, ".");
      }
      
      counter.innerText = `${prefix}${formattedVal}${suffix}`;
      
      if (progress < 1) {
        window.requestAnimationFrame(step);
      } else {
         let finalVal = target >= 1000 ? target.toString().replace(/\B(?=(\d{3})+(?!\d))/g, ".") : target;
         counter.innerText = `${prefix}${finalVal}${suffix}`;
      }
    };
    
    window.requestAnimationFrame(step);
  };

  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        const counters = entry.target.querySelectorAll('.counter');
        counters.forEach(counter => animateCounter(counter));
        observer.unobserve(entry.target); 
      }
    });
  }, { threshold: 0.3 });

  const statsContainer = document.getElementById('stats-container');
  if(statsContainer) {
    observer.observe(statsContainer);
  }

  // LÓGICA DO SLIDER (SETAS NO DESKTOP)
  const sliderContainer = document.getElementById('slider-container');
  const btnPrev = document.getElementById('btn-prev');
  const btnNext = document.getElementById('btn-next');

  if (sliderContainer && btnPrev && btnNext) {
    // A largura do card é 320px + gap de 24px = 344px de deslocamento
    const scrollAmount = 344; 

    btnPrev.addEventListener('click', () => {
      sliderContainer.scrollBy({ left: -scrollAmount, behavior: 'smooth' });
    });

    btnNext.addEventListener('click', () => {
      sliderContainer.scrollBy({ left: scrollAmount, behavior: 'smooth' });
    });
  }
</script>