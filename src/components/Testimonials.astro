---
// Substitua por caminhos das imagens reais dos prints de WhatsApp cortados bonitinhos na pasta public
const prints = [
  "/print6.jpeg", // Ex: Crie uma imagem public/print1.jpg com um print real
  "/print2.jpeg",
  "/print3.jpeg",
  "/print5.jpeg"
];
---
<section class="py-20 bg-[#0A2F5C] overflow-hidden" id="depoimentos">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    
    <div class="flex flex-col lg:flex-row lg:justify-between lg:items-end mb-12">
      <div class="text-center lg:text-left max-w-2xl">
        <h2 class="text-[20px] md:text-4xl font-extrabold text-white mb-4">O que dizem sobre nossa entrega</h2>
        <p class="text-slate-300">Não acredite apenas em nós. Veja o que quem já vivenciou a experiência Cas4 tem a dizer.</p>
      </div>

      <div class="hidden lg:flex gap-3 mt-8 lg:mt-0 shrink-0">
        <button id="btn-prev-test" aria-label="Anterior" class="w-12 h-12 rounded-full bg-transparent border border-[#B28D42] flex items-center justify-center text-[#B28D42] hover:bg-[#B28D42] hover:text-[#0A2F5C] transition-all duration-300 shadow-sm group">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 transition-transform group-hover:-translate-x-1" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
        </button>
        <button id="btn-next-test" aria-label="Próximo" class="w-12 h-12 rounded-full bg-transparent border border-[#B28D42] flex items-center justify-center text-[#B28D42] hover:bg-[#B28D42] hover:text-[#0A2F5C] transition-all duration-300 shadow-sm group">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 transition-transform group-hover:translate-x-1" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
        </button>
      </div>
    </div>

    <div id="testimonial-slider-container" class="flex overflow-x-auto snap-x snap-mandatory gap-6 pb-8 hide-scrollbar scroll-smooth" style="scrollbar-width: none;">
      {prints.map((img, i) => (
        <div class="snap-center shrink-0 w-[280px] md:w-[320px] bg-white rounded-2xl p-2 shadow-xl transform transition hover:-translate-y-2 cursor-grab active:cursor-grabbing">
          <div class="w-full h-[400px] bg-slate-100 rounded-xl flex items-center justify-center overflow-hidden relative">
             <img src={img} alt={`Depoimento ${i + 1} WhatsApp`} class="w-full h-full object-cover" onerror="this.style.display='none'" />
             <div class="absolute text-slate-400 text-sm text-center px-4 -z-10">Coloque seu print do WhatsApp em<br/><b>public{img}</b></div>
          </div>
        </div>
      ))}
    </div>
    
  </div>
</section>

<script>
  // LÓGICA DO SLIDER DE DEPOIMENTOS
  const testSlider = document.getElementById('testimonial-slider-container');
  const btnPrevTest = document.getElementById('btn-prev-test');
  const btnNextTest = document.getElementById('btn-next-test');

  if (testSlider && btnPrevTest && btnNextTest) {
    // Largura do card (320px) + gap (24px) = 344px
    const scrollAmountTest = 344; 

    btnPrevTest.addEventListener('click', () => {
      testSlider.scrollBy({ left: -scrollAmountTest, behavior: 'smooth' });
    });

    btnNextTest.addEventListener('click', () => {
      testSlider.scrollBy({ left: scrollAmountTest, behavior: 'smooth' });
    });
  }
</script>

<style>
  /* Oculta a barra de rolagem feia, mantendo o scroll funcionando */
  .hide-scrollbar::-webkit-scrollbar {
    display: none;
  }
</style>