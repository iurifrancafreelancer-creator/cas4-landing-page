---
// Array completo de projetos com as 21 fotos reais
const projects = [
  { src: "/portfolio/portfolio19.webp", thumb: "/portfolio/portfolio19.webp", caption: "Piso Vinílico Tarkett Injoy Papoula - Paginação Escama de Peixe" },
  { src: "/portfolio/portfolio2.webp", thumb: "/portfolio/portfolio2.webp", caption: "Piso Vinílico SPC Click Tarkett Ambienta Tech Minerium Dark Grey" },
  { src: "/portfolio/portfolio7.webp", thumb: "/portfolio/portfolio7.webp", caption: "Piso Vinílico Tarkett Injoy Camélia" },
  { src: "/portfolio/portfolio11.webp", thumb: "/portfolio/portfolio11.webp", caption: "Detalhe calafetação rodapé" },
  { src: "/portfolio/portfolio8.webp", thumb: "/portfolio/portfolio8.webp", caption: "Piso Laminado PSA Floor Rapolano" },
  { src: "/portfolio/portfolio3.webp", thumb: "/portfolio/portfolio3.webp", caption: "Detalhe acabamento perfil laminado" },
  { src: "/portfolio/portfolio1.webp", thumb: "/portfolio/portfolio1.webp", caption: "Detalhe acabamento rodapé." },
  { src: "/portfolio/portfolio4.webp", thumb: "/portfolio/portfolio4.webp", caption: "Piso Laminado Quick-Step Première Mocha" },
  { src: "/portfolio/portfolio5.webp", thumb: "/portfolio/portfolio5.webp", caption: "Piso Vinílico Ecomex EcoHome Nantes" },
  { src: "/portfolio/portfolio6.webp", thumb: "/portfolio/portfolio6.webp", caption: "Piso Laminado Quick-Step Vision Cumaru Tefé" },
  { src: "/portfolio/portfolio9.webp", thumb: "/portfolio/portfolio9.webp", caption: "Piso Vinílico em placa Arquitech Chateau Amboise" },
  { src: "/portfolio/portfolio12.webp", thumb: "/portfolio/portfolio12.webp", caption: "Piso Laminado PSA Floor Siena" },
  { src: "/portfolio/portfolio13.webp", thumb: "/portfolio/portfolio13.webp", caption: "Piso Laminado Quick-Step Première Ipê Ábano" },
  { src: "/portfolio/portfolio14.webp", thumb: "/portfolio/portfolio14.webp", caption: "Piso Vinílico em placa Ecomex EcoHard Square Maiorca" },
  { src: "/portfolio/portfolio15.webp", thumb: "/portfolio/portfolio15.webp", caption: "Piso Vinílico Arquitech Magnifique Sophie" },
  { src: "/portfolio/portfolio16.webp", thumb: "/portfolio/portfolio16.webp", caption: "Piso Laminado Quick-Step Vision Carvalho Sereno" },
  { src: "/portfolio/portfolio17.webp", thumb: "/portfolio/portfolio17.webp", caption: "Piso Vinílico Eucafloor Basic Kansas" },
  { src: "/portfolio/portfolio18.webp", thumb: "/portfolio/portfolio18.webp", caption: "Piso Vinílico Biancogres Vita Vernazza" },
  { src: "/portfolio/portfolio20.webp", thumb: "/portfolio/portfolio20.webp", caption: "Piso Vinílico SPC Click Ecomex EcoPremium Toulon" },
  { src: "/portfolio/portfolio21.webp", thumb: "/portfolio/portfolio21.webp", caption: "Piso Laminado Quick-Step Smart Carvalho Vanilla" }
];
---
<section class="py-12 md:py-20 bg-white" id="portfolio">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    
    <div class="flex flex-col md:flex-row justify-between items-end mb-8 md:mb-12">
      <div class="max-w-2xl">
        <h2 class="text-[20px] md:text-4xl font-extrabold text-[#0A2F5C] mb-2 md:mb-4 leading-tight">
          Nosso padrão de entrega
        </h2>
        <p class="text-[14px] md:text-lg text-slate-600 leading-relaxed">
          Toque nas imagens para acessar nossa galeria e ver os detalhes que fazem a diferença.
        </p>
      </div>
      <a href="https://wa.me/55SEUNUMERO" target="_blank" class="hidden md:inline-flex mt-4 md:mt-0 text-[#B28D42] font-bold hover:text-[#0A2F5C] transition-colors items-center">
        Quero esse resultado na minha casa <span class="ml-2">→</span>
      </a>
    </div>

    <div class="grid grid-cols-2 lg:grid-cols-4 gap-4 md:gap-6">
      {projects.slice(0, 4).map((project, index) => (
        <button 
          class="gallery-trigger group cursor-pointer focus:outline-none w-full h-40 md:h-64 rounded-2xl overflow-hidden relative shadow-sm border border-slate-100"
          data-index={index}
          aria-label="Abrir galeria de imagens"
        >
          <img 
            src={project.thumb} 
            alt={`Prévia Projeto ${index + 1}`} 
            class="w-full h-full object-cover transform group-hover:scale-110 transition-transform duration-700"
            loading="lazy"
          />
          
          <div class={`absolute inset-0 transition-all duration-300 flex items-center justify-center ${index === 3 ? 'bg-[#0A2F5C]/60' : 'bg-[#0A2F5C]/0 group-hover:bg-[#0A2F5C]/40'}`}>
            {index === 3 ? (
              <span class="text-white font-bold text-lg md:text-xl drop-shadow-md">+{projects.length - 4} Fotos</span>
            ) : (
              <svg class="w-10 h-10 text-white drop-shadow-md opacity-0 group-hover:opacity-100 transition-opacity" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0zM10 7v3m0 0v3m0-3h3m-3 0H7"></path></svg>
            )}
          </div>
        </button>
      ))}
    </div>
  </div>
</section>

<dialog id="image-lightbox" class="bg-transparent m-auto p-0 max-w-full max-h-full w-full h-full backdrop:bg-[#051830]/98 fixed inset-0 z-[100] overflow-hidden">
  
  <div class="relative w-full h-full flex flex-col items-center justify-center p-2 sm:p-8">
    
    <button id="close-lightbox" class="absolute top-4 right-4 sm:top-8 sm:right-8 text-white/70 hover:text-white transition-colors p-2 z-[110] focus:outline-none" aria-label="Fechar galeria">
      <svg class="w-8 h-8 md:w-10 md:h-10 drop-shadow-lg" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
    </button>
    
    <div class="relative max-w-5xl w-full flex-1 flex items-center justify-center px-12 md:px-20">
      
      <button id="prev-btn" class="absolute left-2 md:left-4 top-1/2 -translate-y-1/2 text-white/70 hover:text-white bg-black/20 hover:bg-black/50 rounded-full p-2 md:p-3 transition-all focus:outline-none z-[110]">
        <svg class="w-6 h-6 md:w-8 md:h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path></svg>
      </button>

      <img id="lightbox-img" src="" alt="Projeto Cas4 Ampliado" class="max-w-full max-h-[75vh] object-contain rounded-lg shadow-2xl transition-opacity duration-200 opacity-0" />

      <button id="next-btn" class="absolute right-2 md:right-4 top-1/2 -translate-y-1/2 text-white/70 hover:text-white bg-black/20 hover:bg-black/50 rounded-full p-2 md:p-3 transition-all focus:outline-none z-[110]">
        <svg class="w-6 h-6 md:w-8 md:h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
      </button>
      
    </div>

    <div class="mt-4 mb-8 max-w-3xl text-center px-6">
      <p id="lightbox-caption" class="text-white text-[14px] md:text-lg font-medium tracking-wide drop-shadow-md"></p>
      <p id="lightbox-counter" class="text-[#B28D42] text-xs font-bold mt-2 tracking-widest"></p>
    </div>

  </div>
</dialog>

<script define:vars={{ projects }}>
  document.addEventListener('DOMContentLoaded', () => {
    const dialog = document.getElementById('image-lightbox');
    const triggers = document.querySelectorAll('.gallery-trigger');
    const img = document.getElementById('lightbox-img');
    const caption = document.getElementById('lightbox-caption');
    const counter = document.getElementById('lightbox-counter');
    const closeBtn = document.getElementById('close-lightbox');
    const prevBtn = document.getElementById('prev-btn');
    const nextBtn = document.getElementById('next-btn');

    let currentIndex = 0;

    // Atualiza a imagem, legenda e contador
    const updateGallery = (index) => {
      currentIndex = index;
      img.classList.remove('opacity-100');
      img.classList.add('opacity-0');
      
      // Pequeno delay para o efeito de fade-out e fade-in suave
      setTimeout(() => {
        img.src = projects[currentIndex].src;
        caption.textContent = projects[currentIndex].caption;
        counter.textContent = `${currentIndex + 1} / ${projects.length}`;
        
        img.onload = () => {
          img.classList.remove('opacity-0');
          img.classList.add('opacity-100');
        };
      }, 150);
    };

    // Abre o modal na foto clicada
    const openLightbox = (index) => {
      document.body.style.overflow = 'hidden';
      updateGallery(index);
      dialog.showModal();
    };

    // Fecha o modal
    const closeLightbox = () => {
      document.body.style.overflow = '';
      img.classList.remove('opacity-100');
      img.classList.add('opacity-0');
      
      setTimeout(() => {
        dialog.close();
        img.src = '';
      }, 200); 
    };

    // Clique nas 4 miniaturas
    triggers.forEach(trigger => {
      trigger.addEventListener('click', () => {
        const index = parseInt(trigger.getAttribute('data-index'));
        openLightbox(index);
      });
    });

    // Botão Voltar (<)
    prevBtn.addEventListener('click', (e) => {
      e.stopPropagation(); // Evita fechar o modal
      let newIndex = currentIndex === 0 ? projects.length - 1 : currentIndex - 1;
      updateGallery(newIndex);
    });

    // Botão Avançar (>)
    nextBtn.addEventListener('click', (e) => {
      e.stopPropagation(); // Evita fechar o modal
      let newIndex = currentIndex === projects.length - 1 ? 0 : currentIndex + 1;
      updateGallery(newIndex);
    });

    // Fechar ao clicar no X ou fora da imagem
    closeBtn.addEventListener('click', closeLightbox);
    dialog.addEventListener('click', (e) => {
      if (e.target === dialog || e.target === dialog.firstElementChild) {
        closeLightbox();
      }
    });

    // Acessibilidade: Navegar com setas do teclado e fechar com ESC
    dialog.addEventListener('cancel', closeLightbox);
    document.addEventListener('keydown', (e) => {
      if (!dialog.open) return;
      if (e.key === 'ArrowLeft') prevBtn.click();
      if (e.key === 'ArrowRight') nextBtn.click();
    });
  });
</script>

<style>
  dialog::backdrop {
    background-color: rgba(5, 24, 48, 0.98); /* Fundo um pouco mais escuro para destacar as fotos */
  }
</style>