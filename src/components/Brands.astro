---
// Salve as logos na sua pasta 'public/logos/' com os nomes exatos configurados abaixo.
const brands = [
  { name: "Tarkett", logo: "/logos/tarkett.webp" },
  { name: "Quick-Step", logo: "/logos/quick-step.svg" },
  { name: "Durafloor", logo: "/logos/durafloor.webp" },
  { name: "Eucafloor", logo: "/logos/eucafloor.webp" },
  { name: "Santa Luzia", logo: "/logos/santa-luzia.webp" },
  { name: "Arquitech", logo: "/logos/arquitech.webp" },
  { name: "Biancogres", logo: "/logos/biancogres.webp" },
  { name: "Ecomex", logo: "/logos/ecomex.webp" },
  { name: "Gart", logo: "/logos/logo_gart.webp" },
];
---
<section class="py-10 border-t border-b border-slate-100 bg-white overflow-hidden">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <p class="text-center text-xs md:text-sm font-bold text-slate-400 uppercase tracking-widest mb-8 md:mb-10">
      Homologados pelas maiores indústrias do mercado
    </p>
    
    <div class="relative flex overflow-hidden mask-esteira cursor-default">
      
      <div class="flex items-center gap-8 md:gap-16 pr-8 md:pr-16 w-max animate-esteira hover:[animation-play-state:paused] transition-all duration-500">
        
        {brands.map(brand => (
          <div class="w-24 md:w-32 flex-shrink-0 flex items-center justify-center group opacity-70 hover:opacity-100 transition-opacity duration-300">
            <img 
              src={brand.logo} 
              alt={`Logo ${brand.name}`} 
              title={brand.name}
              class="max-w-full h-auto object-contain filter grayscale group-hover:grayscale-0 group-hover:scale-110 transition-all duration-300" 
              loading="lazy"
              onerror="this.style.display='none'"
            />
          </div>
        ))}

        {brands.map(brand => (
          <div class="w-24 md:w-32 flex-shrink-0 flex items-center justify-center group opacity-70 hover:opacity-100 transition-opacity duration-300">
            <img 
              src={brand.logo} 
              alt={`Logo ${brand.name}`} 
              title={brand.name}
              class="max-w-full h-auto object-contain filter grayscale group-hover:grayscale-0 group-hover:scale-110 transition-all duration-300" 
              loading="lazy"
              onerror="this.style.display='none'"
            />
          </div>
        ))}

      </div>
    </div>
  </div>
</section>

<style>
  /* A máscara e animação agora valem para TODAS as telas (removido o @media) */
  
  /* Cria o desbotamento suave (fade) nas laterais esquerda e direita */
  .mask-esteira {
    mask-image: linear-gradient(to right, transparent, black 10%, black 90%, transparent);
    -webkit-mask-image: linear-gradient(to right, transparent, black 10%, black 90%, transparent);
  }
  
  /* Velocidade da esteira: Aumentei para 25s para ficar elegante e legível no desktop */
  .animate-esteira {
    animation: esteira 25s linear infinite;
  }
  
  /* A engrenagem da esteira: Move a pista 50% para a esquerda, 
     quando termina, ela volta ao zero instantaneamente de forma invisível */
  @keyframes esteira {
    0% { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }
</style>