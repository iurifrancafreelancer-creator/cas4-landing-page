---
const benefits = [
  { title: "Conforto Acústico", desc: "Sem som de 'toc-toc no vinílico'", icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15.536 8.464a5 5 0 010 7.072m2.828-9.9a9 9 0 010 12.728M5.586 15H4a1 1 0 01-1-1v-4a1 1 0 011-1h1.586l4.707-4.707C10.923 3.663 12 4.109 12 5v14c0 .891-1.077 1.337-1.707.707L5.586 15z"></path>`},
  { title: "Conforto Térmico", desc: "Agradável o ano todo", icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"></path>` },
  { title: "Instalação Rápida", desc: "Sem sujeira e entulho", icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>` },
  { title: "Ideal para Pets", desc: "Seguro para seu animal", icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 13a3 3 0 11-6 0 3 3 0 016 0zm6 3a3 3 0 11-6 0 3 3 0 016 0zM9 16a3 3 0 11-6 0 3 3 0 016 0zm3-11a3 3 0 11-6 0 3 3 0 016 0z"></path>` },
  { title: "Fácil de Limpar", desc: "Praticidade no dia a dia", icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z"></path>` },
  { 
    title: "Imune a Cupins", 
    desc: "Zero dor de cabeça", 
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z"></path>` 
  },
  { 
    title: "Hipoalérgicos", 
    desc: "Resistente a água e mofo", 
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 22a7 7 0 0 0 7-7c0-2-1-3.9-3-5.5s-3.5-4-4-6.5c-.5 2.5-2 4.9-4 6.5C6 11.1 5 13 5 15a7 7 0 0 0 7 7z"></path>` 
  },
  { 
    title: "Não risca", 
    desc: "Material resistente a arranhões", 
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09zM18.259 8.715L18 9.75l-.259-1.035a3.375 3.375 0 00-2.455-2.456L14.25 6l1.036-.259a3.375 3.375 0 002.455-2.456L18 2.25l.259 1.035a3.375 3.375 0 002.456 2.456L21.75 6l-1.035.259a3.375 3.375 0 00-2.456 2.456z"></path>` 
  },
  { 
    title: "Sustentavel", 
    desc: "Feito com produtos 100% recicláveis", 
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M11 20A7 7 0 0 1 9.8 6.1C15.5 5 17 4.48 19 2c1 2 2 4.18 2 8 0 5.5-4.78 10-10 10Z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M2 22l10-10"></path>` 
  }
];
---
<section class="py-12 md:py-24 bg-slate-50 overflow-hidden" id="solucoes">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    
    <div class="text-center max-w-2xl mx-auto mb-10 md:mb-14 px-4 sm:px-0">
      <h2 class="text-[20px] md:text-4xl font-extrabold text-[#0A2F5C] mb-3 md:mb-4 leading-tight">
        Piso laminado de madeira ou piso colado? Você que escolhe
      </h2>
      <p class="text-[14px] md:text-lg text-slate-600">
        Nossas linhas de acabamento fazem você esquecer do básico. Selecionamos apenas os materiais que entregam alta durabilidade, conforto térmico e visual de revista.
      </p>
    </div>

    <div class="flex md:grid md:grid-cols-3 overflow-x-auto snap-x snap-mandatory gap-6 pb-8 hide-scrollbar -mx-4 px-4 md:mx-0 md:px-0 max-w-6xl mx-auto">
      
      <div class="snap-center shrink-0 w-[85%] md:w-auto flex flex-col bg-white rounded-3xl overflow-hidden shadow-sm border border-slate-100 group">
        <div class="h-48 md:h-64 w-full overflow-hidden relative bg-slate-200">
          <div class="absolute top-4 left-4 bg-white/95 backdrop-blur-sm text-[#0A2F5C] text-[10px] md:text-xs font-bold px-3 py-1.5 rounded-full uppercase tracking-wider z-10 shadow-sm">
            Mais Escolhido
          </div>
          <img src="https://images.unsplash.com/photo-1581858726788-75bc0f6a952d?q=80&w=800&auto=format&fit=crop" alt="Piso Vinílico" class="w-full h-full object-cover transform group-hover:scale-105 transition-transform duration-700" loading="lazy"/>
        </div>
        <div class="p-5 md:p-8 flex-1 flex flex-col justify-start">
          <h3 class="text-[20px] md:text-xl font-bold text-[#0A2F5C] mb-2">Pisos Vinílicos</h3>
          <p class="text-slate-600 text-[14px] md:text-base leading-relaxed mb-4">
            Silêncio absoluto e resistência à umidade. O vinílico abafa os ruídos dos passos, não "estufa" facilmente e traz a textura realista da madeira natural para o seu dia a dia.
          </p>
          
          <div class="mt-auto space-y-2">
            
            <details class="group/accordion border border-slate-200 rounded-xl bg-slate-50 overflow-hidden [&::-webkit-details-marker]:hidden">
              <summary class="cursor-pointer p-3 flex justify-between items-center list-none outline-none hover:bg-slate-100 transition-colors">
                <h4 class="text-[13px] font-bold text-[#0A2F5C]">Piso Vinílico Click (SPC)</h4>
                <span class="transition-transform duration-300 group-open/accordion:rotate-180 text-[#B28D42] text-xs">▼</span>
              </summary>
              <div class="p-4 pt-1 text-[13px] text-slate-600 leading-relaxed border-t border-slate-100">
                Rígido com base mineral. Instalado por encaixe, disfarça pequenas imperfeições da base e é mais resistente estruturalmente.
              </div>
            </details>

            <details class="group/accordion border border-slate-200 rounded-xl bg-slate-50 overflow-hidden [&::-webkit-details-marker]:hidden">
              <summary class="cursor-pointer p-3 flex justify-between items-center list-none outline-none hover:bg-slate-100 transition-colors">
                <h4 class="text-[13px] font-bold text-[#0A2F5C]">Piso Vinílico Colado (LVT)</h4>
                <span class="transition-transform duration-300 group-open/accordion:rotate-180 text-[#B28D42] text-xs">▼</span>
              </summary>
              <div class="p-4 pt-1 text-[13px] text-slate-600 leading-relaxed border-t border-slate-100">
                Flexível, exige contrapiso liso (massa autonivelante). Entrega a melhor acústica possível para o ambiente (zero "toc-toc").
              </div>
            </details>

          </div>
        </div>
      </div>

      <div class="snap-center shrink-0 w-[85%] md:w-auto flex flex-col bg-white rounded-3xl overflow-hidden shadow-sm border border-slate-100 group">
        <div class="h-48 md:h-64 w-full overflow-hidden relative bg-slate-200">
          <img src="https://cdn3.quick-step.com/-/media/imported%20assets/flooring/8/9/b/qsvr402interior01jpg243752/square%20lr.ashx?rev=978def42de354103976cc269aaf62248&mw=768&hash=014A4AFD9B468C6DCB1DAA981BCC29B9" alt="Piso Laminado" class="w-full h-full object-cover transform group-hover:scale-105 transition-transform duration-700" loading="lazy"/>
        </div>
        <div class="p-5 md:p-8 flex-1 flex flex-col justify-start">
          <h3 class="text-[20px] md:text-xl font-bold text-[#0A2F5C] mb-2">Pisos Laminados</h3>
          <p class="text-slate-600 text-[14px] md:text-base leading-relaxed">
            Excelente custo-benefício e durabilidade extrema. Ele é instalado por encaixe (click) e feito para aguentar o tranco de áreas com grande circulação (como salas e corredores) sem perder o brilho e a elegância.
          </p>
        </div>
      </div>

      <div class="snap-center shrink-0 w-[85%] md:w-auto flex flex-col bg-white rounded-3xl overflow-hidden shadow-sm border border-slate-100 group">
        <div class="h-48 md:h-64 w-full overflow-hidden relative bg-slate-200">
          <div class="absolute top-4 left-4 bg-[#B28D42] text-white text-[10px] md:text-xs font-bold px-3 py-1.5 rounded-full uppercase tracking-wider z-10 shadow-sm">
            Acabamento Premium
          </div>
          <img src="/portfolio/portfolio11.JPG" alt="Rodapés e Persianas" class="w-full h-full object-cover transform group-hover:scale-105 transition-transform duration-700" loading="lazy"/>
        </div>
        <div class="p-5 md:p-8 flex-1 flex flex-col justify-start">
          <h3 class="text-[20px] md:text-xl font-bold text-[#0A2F5C] mb-2">Rodapés & Guarnições</h3>
          <p class="text-slate-600 text-[14px] md:text-base leading-relaxed">
            Rodapés de alturas diferentes, que protegem e escondem fiações.
          </p>
        </div>
      </div>

    </div>

    <h3 class="text-xl font-bold text-center text-[#0A2F5C] mb-8">Vantagens que transformam o seu dia a dia</h3>
    
    <div class="flex md:flex-wrap md:justify-center overflow-x-auto md:overflow-visible snap-x snap-mandatory gap-4 md:gap-6 pb-6 hide-scrollbar -mx-4 px-4 md:mx-0 md:px-0">
      
      {benefits.map(benefit => (
        /* LARGURAS CORRIGIDAS: w-[45%] no mobile, lg:w-[180px] para fixar o tamanho no desktop e forçar a quebra centralizada */
        <div class="snap-center shrink-0 w-[45%] sm:w-[160px] lg:w-[180px] xl:w-[190px] flex flex-col items-center justify-center bg-white border border-slate-100 rounded-2xl p-4 md:p-5 text-center shadow-sm hover:shadow-md hover:border-[#B28D42]/40 transition-all">
          <div class="w-12 h-12 rounded-full bg-[#0A2F5C]/5 text-[#B28D42] flex items-center justify-center mb-3">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" set:html={benefit.icon} />
          </div>
          <h4 class="font-bold text-slate-800 text-sm mb-1">{benefit.title}</h4>
          <p class="text-[10px] md:text-xs text-slate-500">{benefit.desc}</p>
        </div>
      ))}

    </div>
  </div>
</section>